<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SkillBridge - Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">SkillBridge</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/skills">Browse skills</a>
                <% if (user) { %>
                    <a class="nav-link" href="/dashboard">Dashboard</a>
                    <a class="nav-link" href="/logout">Log out</a>
                <% } else { %>
                    <a class="nav-link" href="/login">Log in</a>
                    <a class="nav-link" href="/register">Register</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container py-5 text-center">
        <h1 class="display-4">Welcome to SkillBridge</h1>
        <p class="lead">Share what you know. Learn what you don't.</p>
        <a href="/skills" class="btn btn-primary btn-lg mt-3">Browse skills</a>
        <% if (!user) { %>
            <a href="/register" class="btn btn-outline-secondary btn-lg mt-3">Join now</a>
        <% } %>
    </div>
</body>
</html>
