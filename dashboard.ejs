<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>SkillBridge - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">SkillBridge</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" href="/skills">Browse skills</a>
                <a class="nav-link" href="/bookings">My bookings</a>
                <a class="nav-link" href="/profile">Profile</a>
                <% if (user && user.role === 'admin') { %>
                    <a class="nav-link" href="/admin">Admin</a>
                <% } %>
                <a class="nav-link" href="/logout">Log out</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <% if (messages.length > 0) { %>
            <div class="alert alert-success"><%= messages[0] %></div>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Hello, <%= user.username %></h2>
            <a href="/skills/add" class="btn btn-primary">Add a skill</a>
        </div>

        <h5>My skills</h5>
        <% if (mySkills.length === 0) { %>
            <p class="text-muted">You haven't listed any skills yet. Add one to get started.</p>
        <% } else { %>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Rate ($/hr)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% mySkills.forEach(skill => { %>
                        <tr>
                            <td><%= skill.title %></td>
                            <td><%= skill.category %></td>
                            <td><%= skill.rate %></td>
                            <td>
                                <a href="/skills/edit/<%= skill.id %>" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a href="/skills/delete/<%= skill.id %>" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Delete this skill?')">Delete</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>
</html>
