<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Listing | SkillBridge</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <%- include('partials/navbar', { user: user }) %>

        <main class="listing-page">
            <section class="listing-form-box">
                <h1>Edit Listing</h1>
                <p class="form-description">Update the details of your skill listing.</p>

                <form action="/skills/<%= skill.skill_id %>/edit" method="POST" class="listing-form">

                    <label for="title">Skill title</label>
                    <input type="text" id="title" name="title" value="<%= skill.title %>" required>

                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="5" required><%= skill.description %></textarea>

                    <label for="category">Category</label>
                    <input type="text" id="category" name="category" value="<%= skill.category %>" required>

                    <label for="level">Skill level</label>
                    <select id="level" name="level" required>
                        <option value="beginner" <%=skill.level==='beginner' ? 'selected' : '' %>>Beginner</option>
                        <option value="intermediate" <%=skill.level==='intermediate' ? 'selected' : '' %>>Intermediate
                        </option>
                        <option value="advanced" <%=skill.level==='advanced' ? 'selected' : '' %>>Advanced</option>
                    </select>

                    <label for="duration">Lesson duration (hours)</label>
                    <input type="number" id="duration" name="duration" value="<%= skill.duration %>" min="1" required>

                    <label for="mode">Lesson mode</label>
                    <select id="mode" name="mode" required>
                        <option value="online" <%=skill.mode==='online' ? 'selected' : '' %>>Online</option>
                        <option value="offline" <%=skill.mode==='offline' ? 'selected' : '' %>>In person</option>
                        <option value="hybrid" <%=skill.mode==='hybrid' ? 'selected' : '' %>>Both online and in person
                        </option>
                    </select>

                    <button type="submit" class="btn btn-register">Save Changes</button>
                </form>
            </section>
        </main>
</body>

</html>