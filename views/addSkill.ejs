<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Listing | SkillBridge</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <%- include('partials/navbar', { user: user }) %>

        <main class="listing-page">
            <section class="listing-form-box">
                <h1>Create New Skill Course</h1>
                <p class="form-description">Add the skill that you would like to teach.</p>

                <form action="/skills/add" method="POST" class="listing-form">

                    <label for="title">Skill title</label>
                    <input type="text" id="title" name="title" placeholder="Example: Beginner Guitar Lessons" required>

                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="5"
                        placeholder="Describe what students will learn." required></textarea>

                    <label for="category">Category</label>
                    <input type="text" id="category" name="category" placeholder="Example: Music" required>

                    <label for="level">Skill level</label>
                    <select id="level" name="level" required>
                        <option value="">Choose a level</option>
                        <option value="beginner">Beginner</option>
                        <option value="intermediate">Intermediate</option>
                        <option value="advanced">Advanced</option>
                    </select>

                    <label for="duration">Lesson duration (hours)</label>
                    <input type="number" id="duration" name="duration" min="1" placeholder="1" required>

                    <label for="mode">Lesson mode</label>
                    <select id="mode" name="mode" required>
                        <option value="">Choose a mode</option>
                        <option value="online">Online</option>
                        <option value="offline">In person</option>
                        <option value="hybrid">Both online and in person</option>
                    </select>

                    <button type="submit" class="btn btn-register">Create Skill Course</button>
                </form>
            </section>
        </main>
</body>

</html>