<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - SkillBridge</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <%- include('partials/navbar', { user: user }) %>

  <h1>Dashboard</h1>

  <% if (user.role === 'instructor' || user.role === 'admin') { %>
    <a href="/skills/add"><button>+ Add New Course</button></a>
  <% } %>

  <h2>All Courses</h2>

  <% if (skills.length === 0) { %>
    <p>No courses available yet.</p>
  <% } else { %>
    <table border="1" cellpadding="8">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Level</th>
          <th>Duration</th>
          <th>Mode</th>
          <th>Instructor</th>
          <% if (user.role === 'instructor' || user.role === 'admin') { %>
            <th>Actions</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% skills.forEach(skill => { %>
          <tr>
            <td><%= skill.title %></td>
            <td><%= skill.category %></td>
            <td><%= skill.level %></td>
            <td><%= skill.duration %> hr</td>
            <td><%= skill.mode %></td>
            <td><%= skill.instructor_username || skill.instructor_id %></td>

            <% if (user.role === 'admin' || (user.role === 'instructor' && skill.instructor_id === user.id)) { %>
              <td>
                <a href="/skills/<%= skill.skill_id %>/edit"><button>Edit</button></a>
                <form action="/skills/<%= skill.skill_id %>/delete" method="POST" style="display:inline;">
                  <button type="submit" onclick="return confirm('Delete this skill course?')">Delete</button>
                </form>
              </td>
            <% } else if (user.role === 'instructor' || user.role === 'admin') { %>
              <td>&mdash;</td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

</body>
</html>