<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Profile Page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <!-- Profile page  Content -->
  <div class="container">
    <h2 class="mt-4">My Profile</h2>
    <% if (profile.length === 0) { %>
      <p>No valid profile found .</p>
    <% } else { %>
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>Profile Picture</th>
            <th>Name</th>
            <th>Account Type</th>
            <th>Contact No</th>
            <th>Address</th>
            <th>Action </th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < profile.length; i++) { %>
            <tr>
           <td>
            <img 
            src="/images/<%=profile[i].profilepicture%>"
            width="100"
            class="img-thumbnail">
            </td>
                <td><%= profile[i].name %></td>
                <td><%= profile[i].accountType %></td>
                <td><%= profile[i].contactNo %></td>
                <td><%= profile[i].address %></td>
                <td>
                  
                </td>
            </tr>
            <% } %>
            </tbody>
            </table>
          
      
      
      
      <h2>My Progress</h2>
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>Course</th>
            <th>Progress %</th>
            <th>Date started</th>
          </tr>
        </thead>
        <tbody>
          
          <% for (let i = 0; i < learningHistory.length; i++) { %>
            <tr>
                <td><%= learningHistory[i].courseName %></td>
                <td><%= learningHistory[i].progress %>%</td>
                <td><%= learningHistory[i].dateStarted %></td>
            </tr>
          <% } %>
        </tbody>
      </table>


      <div class="mt-4">
        
      </div>
    <% } %>
  </div>
</body>
</html>

