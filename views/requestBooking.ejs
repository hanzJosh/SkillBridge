<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Request a Lesson - SkillBridge</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    .flash {
      background: #fee2e2; color: #991b1b;
      padding: 10px 16px; border-radius: 8px; margin-bottom: 16px;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { user: user }) %>

  <main class="listing-page">
    <div class="listing-form-box">
      <h1>Request a Lesson</h1>
      <p class="form-description">Pick a skill course, choose a date and time, and the instructor will accept or reject your request.</p>

      <% if (message && message.length > 0) { %>
        <div class="flash"><%= message %></div>
      <% } %>

      <form action="/bookings/new" method="POST" class="listing-form">
        <label for="skill_id">Skill Course</label>
        <select name="skill_id" id="skill_id" required>
          <option value="" disabled <%= selectedSkillId ? '' : 'selected' %>>-- Select a skill course --</option>
          <% skills.forEach(s => { %>
            <option value="<%= s.skill_id %>" <%= String(selectedSkillId) === String(s.skill_id) ? 'selected' : '' %>>
              <%= s.title %> (<%= s.category %>, <%= s.level %>) — by <%= s.instructor_username %>
            </option>
          <% }) %>
        </select>

        <label for="booking_date">Date</label>
        <input type="date" name="booking_date" id="booking_date" required>

        <label for="booking_time">Time</label>
        <input type="time" name="booking_time" id="booking_time" required>

        <script>
          // Block past dates and times
          const dateInput = document.getElementById('booking_date');
          const timeInput = document.getElementById('booking_time');

          function pad(n) { return String(n).padStart(2, '0'); }

          function todayStr() {
            const now = new Date();
            return now.getFullYear() + '-' + pad(now.getMonth() + 1) + '-' + pad(now.getDate());
          }

          function nowTimeStr() {
            const now = new Date();
            return pad(now.getHours()) + ':' + pad(now.getMinutes());
          }

          function updateLimits() {
            dateInput.min = todayStr();
            // If the chosen date is today, the time must be from now onwards
            if (dateInput.value === todayStr()) {
              timeInput.min = nowTimeStr();
              if (timeInput.value && timeInput.value < timeInput.min) {
                timeInput.value = '';
              }
            } else {
              timeInput.removeAttribute('min');
            }
          }

          dateInput.addEventListener('change', updateLimits);
          updateLimits();
        </script>

        <label for="notes">Notes for the instructor (optional)</label>
        <textarea name="notes" id="notes" rows="3" placeholder="Anything the instructor should know..."></textarea>

        <button type="submit" class="btn-primary">Send Request</button>
        <a href="/bookings" class="btn-secondary">Cancel</a>
      </form>
    </div>
  </main>

</body>
</html>
