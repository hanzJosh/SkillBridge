
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= skill.title %> Reviews - SkillBridge</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

  <%- include('partials/navbar', { user: user }) %>

  <main class="review-wrap">
    <div class="review-course-card">
      <span class="badge badge-<%= skill.level %>"><%= skill.level %></span>
      <h1><%= skill.title %></h1>
      <p class="review-course-meta"><%= skill.category %> &middot; taught by <%= skill.instructor_username || 'Unknown' %></p>
    </div>

    <% if (message.length > 0) { %>
      <div class="flash" role="alert"><%= message %></div>
    <% } %>

    <section class="review-form-card">
      <h2>Leave a Review</h2>
      <form action="/skills/<%= skill.skill_id %>/review" method="POST" class="form">
        <div class="field">
          <label for="rating">Rating</label>
          <select name="rating" id="rating" required>
            <option value="">Select a rating</option>
            <option value="5">&#9733;&#9733;&#9733;&#9733;&#9733; &mdash; Excellent</option>
            <option value="4">&#9733;&#9733;&#9733;&#9733; &mdash; Good</option>
            <option value="3">&#9733;&#9733;&#9733; &mdash; Average</option>
            <option value="2">&#9733;&#9733; &mdash; Poor</option>
            <option value="1">&#9733; &mdash; Terrible</option>
          </select>
        </div>

        <div class="field">
          <label for="comment">Comment</label>
          <textarea name="comment" id="comment" rows="4" placeholder="What did you think of this course?"></textarea>
        </div>

        <button type="submit" class="btn btn-register btn-block">Post Review</button>
      </form>
    </section>

    <section class="review-list">
      <h2>What learners are saying</h2>

      <% if (reviews.length === 0) { %>
        <div class="empty-state">
          <p>No reviews yet &mdash; be the first to share your experience.</p>
        </div>
      <% } else { %>
        <% reviews.forEach(review => { %>
          <div class="review-item">
            <div class="review-item-top">
              <strong><%= review.username %></strong>
              <span class="review-stars"><%= '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating) %></span>
            </div>
            <% if (review.comment) { %>
              <p><%= review.comment %></p>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </section>
  </main>

</body>
</html>
