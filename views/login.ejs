<body>
  <div class="auth-wrap">
    <div>
      <a href="/" class="back-link">&larr; SkillBridge</a>

      <section class="form-section">
        <span class="eyebrow">Welcome back</span>
        <h1>Log In</h1>
        <p class="sub">Pick up where you left off.</p>

        <% if (message.length > 0) { %>
          <div class="flash" role="alert"><%= message %></div>
        <% } %>

        <form action="/login" method="POST" class="form" novalidate>
          <div class="field">
            <label for="username">Username</label>
            <input type="text" name="username" id="username" autocomplete="username" autofocus required>
          </div>

          <div class="field password-field">
            <label for="password">Password</label>
            <input type="password" name="password" id="password" autocomplete="current-password" required>
            <button type="button" class="toggle-pw" data-target="password">Show</button>
          </div>

          <button type="submit" class="btn btn-register btn-block">Log In</button>
        </form>

        <p class="foot">Don't have an account? <a href="/register">Register</a></p>
      </section>
    </div>
  </div>

  <script>
    document.querySelectorAll('.toggle-pw').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var input = document.getElementById(btn.dataset.target);
        var showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        btn.textContent = showing ? 'Show' : 'Hide';
      });
    });
  </script>
</body>
</html>
